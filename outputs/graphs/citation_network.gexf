      <node id="AUSTIN J, 2006, ENTREP THEORY PRACT" label="AUSTIN J, 2006, ENTREP THEORY PRACT">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="SOCIAL AND COMMERCIAL ENTREPRENEURSHIP: SAME, DIFFERENT, OR BOTH?" />
          <attvalue for="2" value="" />
          <attvalue for="3" value="JAMES E. AUSTIN; HOWARD H. STEVENSON; JANE WEI–SKILLERN" />

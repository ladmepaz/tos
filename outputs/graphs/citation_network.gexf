      <node id="VARGO STEPHEN L, 2008, EUROPEAN MANAGEMENT JOURNAL" label="VARGO STEPHEN L, 2008, EUROPEAN MANAGEMENT JOURNAL">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="ON VALUE AND VALUE CO-CREATION: A SERVICE SYSTEMS AND SERVICE LOGIC PERSPECTIVE" />
          <attvalue for="2" value="" />
          <attvalue for="3" value="STEPHEN L. VARGO; PAUL P. MAGLIO; MELISSA ARCHPRU AKAKA" />
          <attvalue for="4" value="HTTPS://ORCID.ORG/0000-0002-2401-8358; HTTPS://ORCID.ORG/0000-0002-6846-5635; HTTPS://ORCID.ORG/0000-0003-2088-255X" />

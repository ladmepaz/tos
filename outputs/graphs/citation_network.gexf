      <node id="LICHTENTHALER U, 2009, ACAD MANAGE J" label="LICHTENTHALER U, 2009, ACAD MANAGE J">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="ABSORPTIVE CAPACITY, ENVIRONMENTAL TURBULENCE, AND THE COMPLEMENTARITY OF ORGANIZATIONAL LEARNING PROCESSES" />
          <attvalue for="2" value="" />

      <node id="ELLIS P, 2010, J INT BUS STUD" label="ELLIS P, 2010, J INT BUS STUD">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="EFFECT SIZES AND THE INTERPRETATION OF RESEARCH RESULTS IN INTERNATIONAL BUSINESS" />
          <attvalue for="2" value="ELLIS P." />

      <node id="HAUSER A, 2020, SMALL BUS ECON" label="HAUSER A, 2020, SMALL BUS ECON">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="STRATEGIC DECISION-MAKING IN SMES: EFFECTUATION, CAUSATION, AND THE ABSENCE OF STRATEGY" />

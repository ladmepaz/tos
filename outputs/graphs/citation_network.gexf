      <node id="MCDOUGALL P, 2000, ACAD MANAGE J" label="MCDOUGALL P, 2000, ACAD MANAGE J">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="INTERNATIONAL ENTREPRENEURSHIP: THE INTERSECTION OF TWO RESEARCH PATHS." />
          <attvalue for="2" value="MCDOUGALL P.P.; OVIATT B.M." />
          <attvalue for="3" value="PATRICIA P. MCDOUGALL; BENJAMIN M. OVIATT" />
          <attvalue for="4" value="; " />
          <attvalue for="5" value="REFLECTING THE INTERNATIONALIZATION OF THE MARKETPLACE AND THE INCREASING PROMINENCE OF ENTREPRENEURIAL FIRMS IN THE GLOBAL ECONOMY, THE RESEARCH PATHS OF INTERNATIONAL BUSINESS AND ENTREPRENEURSHI..." />
          <attvalue for="6" value="2000.0" />
          <attvalue for="7" value="ACADEMY OF MANAGEMENT JOURNAL" />
          <attvalue for="8" value="ACAD MANAGE J" />
          <attvalue for="9" value="" />
          <attvalue for="10" value="10.2307/1556418" />
          <attvalue for="11" value="10.2307/1556418" />

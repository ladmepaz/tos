      <node id="BOSO N, 2013, J BUS VENTURING" label="BOSO N, 2013, J BUS VENTURING">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="ENTREPRENEURIAL ORIENTATION, MARKET ORIENTATION, NETWORK TIES, AND PERFORMANCE: STUDY OF ENTREPRENEURIAL FIRMS IN A DEVELOPING ECONOMY" />
          <attvalue for="2" value="" />
          <attvalue for="3" value="NATHANIEL BOSO; VICKY M. STORY; JOHN W. CADOGAN" />
          <attvalue for="4" value="HTTPS://ORCID.ORG/0000-0001-7043-4793; NO ORCID; HTTPS://ORCID.ORG/0000-0002-8786-9184" />
          <attvalue for="5" value="" />
          <attvalue for="6" value="2013.0" />

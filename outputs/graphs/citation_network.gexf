      <node id="HIRSCHMAN E, 1983, J MARKETING" label="HIRSCHMAN E, 1983, J MARKETING">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="AESTHETICS, IDEOLOGIES AND THE LIMITS OF THE MARKETING CONCEPT" />
          <attvalue for="2" value="HIRSCHMAN E.C." />
          <attvalue for="3" value="ELIZABETH C. HIRSCHMAN" />
          <attvalue for="4" value="" />
          <attvalue for="5" value="IT IS PROPOSED THAT THE MARKETING CONCEPT, AS A NORMATIVE FRAMEWORK, IS NOT APPLICABLE TO TWO BROAD CLASSES OF PRODUCERS BECAUSE OF THE PERSONAL VALUES AND SOCIAL NORMS THAT CHARACTERIZE THE PRODUCTION PROCESS. THESE TWO CLASSES OF PRODUCERS ARE ARTISTS AND IDEOLOGISTS. ARTISTS ARE THOSE WHO CREATE PRIMARILY TO EXPRESS THEIR SUBJECTIVE CONCEPTIONS OF BEAUTY, EMOTION OR SOME OTHER AESTHETIC IDEAL. IDEOLOGISTS ARE THOSE WHO PUT FORWARD AN INTEGRATED SET OF POSITIVE AND NORMATIVE STATEMENTS THAT DESCRIBE WHAT THE WORLD IS AND WHAT IT SHOULD BE." />
          <attvalue for="6" value="1983.0" />
          <attvalue for="7" value="JOURNAL OF MARKETING" />
          <attvalue for="8" value="J MARKETING" />
          <attvalue for="9" value="" />
          <attvalue for="10" value="10.1177/002224298304700306" />
          <attvalue for="11" value="10.1177/002224298304700306" />
        </attvalues>
      </node>

      <node id="WELTER C, 2016, STRATEG ENTREP J" label="WELTER C, 2016, STRATEG ENTREP J">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="BRIDGING BEHAVIORAL MODELS AND THEORETICAL CONCEPTS: EFFECTUATION AND BRICOLAGE IN THE OPPORTUNITY CREATION FRAMEWORK" />

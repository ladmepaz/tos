      <node id="SILK A, 1982, J MARKETING RES" label="SILK A, 1982, J MARKETING RES">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="MEASURING INFLUENCE IN ORGANIZATIONAL PURCHASE DECISIONS" />
          <attvalue for="2" value="SILK A.J.; KALWANI M.U." />
          <attvalue for="3" value="ALVIN J. SILK; MANOHAR U. KALWANI" />
          <attvalue for="4" value="; " />
          <attvalue for="5" value="THE AUTHORS REPORT FINDINGS BEARING ON THE RELIABILITY OF MEASURES USED IN INDUSTRIAL MARKETING RESEARCH SURVEYS TO IDENTIFY THE STRUCTURE OF BUYING GROUPS. RESULTS OBTAINED IN A PILOT STUDY OF THE PURCHASE OF LITHOGRAPHIC PLATES BY SMALL PRINTING FIRMS REVEAL A LACK OF CONSENSUS ABOUT PURCHASE INFLUENCE BETWEEN PAIRS OF INFORMANTS FROM THE SAME ORGANIZATIONS. FURTHER, THE RATINGS APPEAR TO DIFFERENTIATE AMONG ROLES BUT NOT STAGES IN THE DECISION PROCESS." />
          <attvalue for="6" value="1982.0" />
          <attvalue for="7" value="JOURNAL OF MARKETING RESEARCH" />
          <attvalue for="8" value="J MARKETING RES" />
          <attvalue for="9" value="" />
          <attvalue for="10" value="10.1177/002224378201900201" />

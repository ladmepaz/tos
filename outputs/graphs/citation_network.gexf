      <node id="CZAKON W, 2019, LONG RANGE PLANN" label="CZAKON W, 2019, LONG RANGE PLANN">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="COOPETITION STRATEGIES: CRITICAL ISSUES AND RESEARCH DIRECTIONS" />
          <attvalue for="2" value="CZAKON W.; SRIVASTAVA M.K.; ROY F.L.; GNYAWALỊ D.R." />
          <attvalue for="3" value="WOJCIECH CZAKON; MANISH K. SRIVASTAVA; FRÉDÉRIC LE ROY; DEVI R. GNYAWALỊ" />
          <attvalue for="4" value="HTTPS://ORCID.ORG/0000-0002-8329-0829; HTTPS://ORCID.ORG/0000-0003-0917-6021; HTTPS://ORCID.ORG/0000-0002-2842-6359; HTTPS://ORCID.ORG/0000-0001-7470-6231" />
          <attvalue for="5" value="" />

      <node id="MAITLIS S, 2005, ACAD MANAGE J" label="MAITLIS S, 2005, ACAD MANAGE J">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="THE SOCIAL PROCESSES OF ORGANIZATIONAL SENSEMAKING" />
          <attvalue for="2" value="MAITLIS S." />
          <attvalue for="3" value="SALLY MAITLIS" />
          <attvalue for="4" value="HTTPS://ORCID.ORG/0000-0003-1117-7787" />
          <attvalue for="5" value="A LONGITUDINAL STUDY OF THE SOCIAL PROCESSES OF ORGANIZATIONAL SENSEMAKING SUGGESTS THAT THEY UNFOLD IN FOUR DISTINCT FORMS: GUIDED, FRAGMENTED, RESTRICTED, AND MINIMAL. THESE FORMS RESULT FROM THE DEGREE TO WHICH LEADERS AND STAKEHOLDERS ENGAGE IN “SENSEGIVING”—ATTEMPTS TO INFLUENCE OTHERS' UNDERSTANDINGS OF AN ISSUE. EACH OF THE FOUR FORMS OF ORGANIZATIONAL SENSEMAKING IS ASSOCIATED WITH A DISTINCT SET OF PROCESS CHARACTERISTICS THAT CAPTURE THE DOMINANT PATTERN OF INTERACTION. THEY ALSO EACH RESULT IN PARTICULAR OUTCOMES, SPECIFICALLY, THE NATURE OF THE ACCOUNTS AND ACTIONS GENERATED." />
          <attvalue for="6" value="2005.0" />
          <attvalue for="7" value="ACADEMY OF MANAGEMENT JOURNAL" />
          <attvalue for="8" value="ACAD MANAGE J" />
          <attvalue for="9" value="" />
          <attvalue for="10" value="10.5465/AMJ.2005.15993111" />
          <attvalue for="11" value="10.5465/amj.2005.15993111" />
        </attvalues>
      </node>

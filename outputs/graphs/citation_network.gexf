      <node id="MAHAJAN V, 1991" label="MAHAJAN V, 1991">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="NEW PRODUCT DIFFUSION MODELS IN MARKETING: A REVIEW AND DIRECTIONS FOR RESEARCH" />
          <attvalue for="2" value="MAHAJAN V.; MULLER E.; BASS F.M." />
          <attvalue for="3" value="VIJAY MAHAJAN; EITAN MULLER; FRANK M. BASS" />

      <node id="BAIRD I, 1985, ACAD MANAGE REV" label="BAIRD I, 1985, ACAD MANAGE REV">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="TOWARD A CONTINGENCY MODEL OF STRATEGIC RISK TAKING" />
          <attvalue for="2" value="BAIRD I.S.; THOMAS H." />
          <attvalue for="3" value="INGA S. BAIRD; HOWARD THOMAS" />
          <attvalue for="4" value="; HTTPS://ORCID.ORG/0000-0003-2010-2031" />
          <attvalue for="5" value="A MODEL OF STRATEGIC RISK TAKING INCORPORATING ENVIRONMENTAL, INDUSTRIAL, ORGANIZATIONAL, DECISION MAKER, AND PROBLEM VARIABLES IS PRESENTED. THE MODEL IS INTENDED TO BE BOTH A PRELIMINARY CONCEPTUALIZATION OF STRATEGIC RISK TAKING AND A STIMULANT FOR FUTURE RESEARCH ON RISK TAKING IN STRATEGIC MANAGEMENT DECISIONS. RELEVANT RESEARCH FROM A NUMBER OF DISCIPLINES IS SUMMARIZED, AND THE POTENTIAL IMPACTS OF PARTICULAR VARIABLES ON THE PROPENSITY TO TAKE STRATEGIC RISKS ARE EXAMINED." />
          <attvalue for="6" value="1985.0" />
          <attvalue for="7" value="ACADEMY OF MANAGEMENT REVIEW" />
          <attvalue for="8" value="ACAD MANAGE REV" />

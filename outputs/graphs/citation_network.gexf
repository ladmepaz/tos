      <node id="HAMBRICK D, 1984, ACAD MANAGE REV" label="HAMBRICK D, 1984, ACAD MANAGE REV">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="UPPER ECHELONS: THE ORGANIZATION AS A REFLECTION OF ITS TOP MANAGERS" />
          <attvalue for="2" value="HAMBRICK D.C.; MASON P.A." />
          <attvalue for="3" value="DONALD C. HAMBRICK; PHYLLIS A. MASON" />
          <attvalue for="4" value="HTTPS://ORCID.ORG/0000-0003-4154-2538; " />
          <attvalue for="5" value="THEORISTS IN VARIOUS FIELDS HAVE DISCUSSED CHARACTERISTICS OF TOP MANAGERS. THIS PAPER ATTEMPTS TO SYNTHESIZE THESE PREVIOUSLY FRAGMENTED LITERATURES AROUND A MORE GENERAL “UPPER ECHELONS PERSPECTIVE.” THE THEORY STATES THAT ORGANIZATIONAL OUTCOMES—STRATEGIC CHOICES AND PERFORMANCE LEVELS—ARE PARTIALLY PREDICTED BY MANAGERIAL BACKGROUND CHARACTERISTICS. PROPOSITIONS AND METHODOLOGICAL SUGGESTIONS ARE INCLUDED." />
          <attvalue for="6" value="1984.0" />
          <attvalue for="7" value="ACADEMY OF MANAGEMENT REVIEW" />
          <attvalue for="8" value="ACAD MANAGE REV" />
          <attvalue for="9" value="" />
          <attvalue for="10" value="10.5465/AMR.1984.4277628" />
          <attvalue for="11" value="10.5465/amr.1984.4277628" />

        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="EXPORT MARKETING STRATEGY IMPLEMENTATION, EXPORT MARKETING CAPABILITIES, AND EXPORT VENTURE PERFORMANCE" />
          <attvalue for="2" value="MORGAN N.A.; KATSIKEAS C.S.; VORHIES D.W." />
          <attvalue for="3" value="NEIL A. MORGAN; CONSTANTINE S. KATSIKEAS; DOUGLAS W. VORHIES" />

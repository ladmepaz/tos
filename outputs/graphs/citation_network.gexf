      <node id="LYON D, 2000, J MANAGE" label="LYON D, 2000, J MANAGE">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="ENHANCING ENTREPRENEURIAL ORIENTATION RESEARCH: OPERATIONALIZING AND MEASURING A KEY STRATEGIC DECISION MAKING PROCESS" />
          <attvalue for="2" value="LYON D.W.; LUMPKIN G.T.; DESS G.G." />
          <attvalue for="3" value="DOUGLAS W. LYON; G. T. LUMPKIN; GREGORY G. DESS" />
          <attvalue for="4" value="; HTTPS://ORCID.ORG/0000-0003-2282-5196; HTTPS://ORCID.ORG/0000-0001-6183-7881" />
          <attvalue for="5" value="AS A MEANS TO ENHANCE PRESCRIPTIVE THEORY ON A FIRM’S ENTREPRENEURIAL ORIENTATION, THIS PAPER ADDRESSES THE STRENGTHS AND WEAKNESSES OF THREE APPROACHES TO MEASUREMENT: MANAGERIAL PERCEPTIONS, FIRM BEHAVIORS, AND RESOURCE ALLOCATIONS. WE EXAMINE A SET OF RECENT STUDIES EMPLOYING THESE APPROACHES, PROPOSE IMPORTANT CONTINGENCIES REGARDING THEIR USE, AND SUGGEST THAT MEASUREMENT ACCURACY CAN BE IMPROVED BY USING A TRIANGULATION OF METHODS. THE PAPER CONCLUDES WITH A DISCUSSION OF THEORETICAL, RESOURCE AVAILABILITY, AND INTERPRETABILITY CONSIDERATIONS IN MEASUREMENT SELECTION." />
          <attvalue for="6" value="2000.0" />
          <attvalue for="7" value="JOURNAL OF MANAGEMENT" />
          <attvalue for="8" value="J MANAGE" />
          <attvalue for="9" value="" />
          <attvalue for="10" value="10.1177/014920630002600503" />
          <attvalue for="11" value="10.1177/014920630002600503" />
        </attvalues>
      </node>

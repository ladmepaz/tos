      <node id="LINDELL M, 2001, J APPL PSYCHOL" label="LINDELL M, 2001, J APPL PSYCHOL">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="ACCOUNTING FOR COMMON METHOD VARIANCE IN CROSS-SECTIONAL RESEARCH DESIGNS." />
          <attvalue for="2" value="LINDELL M.K.; WHITNEY D.J." />
          <attvalue for="3" value="MICHAEL K. LINDELL; DAVID J. WHITNEY" />
          <attvalue for="4" value="HTTPS://ORCID.ORG/0000-0001-6972-5120; HTTPS://ORCID.ORG/0000-0003-0736-4539" />
          <attvalue for="5" value="CROSS-SECTIONAL STUDIES OF ATTITUDE-BEHAVIOR RELATIONSHIPS ARE VULNERABLE TO THE INFLATION OF CORRELATIONS BY COMMON METHOD VARIANCE (CMV). HERE, A MODEL IS PRESENTED THAT ALLOWS PARTIAL CORRELATION ANALYSIS TO ADJUST THE OBSERVED CORRELATIONS FOR CMV CONTAMINATION AND DETERMINE IF CONCLUSIONS ABOUT THE STATISTICAL AND PRACTICAL SIGNIFICANCE OF A PREDICTOR HAVE BEEN INFLUENCED BY THE PRESENCE OF CMV. THIS METHOD ALSO SUGGESTS PROCEDURES FOR DESIGNING QUESTIONNAIRES TO INCREASE THE PRECISION OF THIS ADJUSTMENT." />
          <attvalue for="6" value="2001.0" />
          <attvalue for="7" value="JOURNAL OF APPLIED PSYCHOLOGY" />
          <attvalue for="8" value="J APPL PSYCHOL" />
          <attvalue for="9" value="" />
          <attvalue for="10" value="10.1037/0021-9010.86.1.114" />

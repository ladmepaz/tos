          <attvalue for="1" value="OPEN INNOVATION: THE MISSING NEXUS BETWEEN ENTREPRENEURIAL ORIENTATION, TOTAL QUALITY MANAGEMENT, AND PERFORMANCE OF SMES" />
          <attvalue for="2" value="" />

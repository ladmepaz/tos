      <node id="WALES WJ, 2021, J BUS RES" label="WALES WJ, 2021, J BUS RES">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="THE STATUS QUO OF RESEARCH ON ENTREPRENEURIAL ORIENTATION: CONVERSATIONAL LANDMARKS AND THEORETICAL SCAFFOLDING" />
          <attvalue for="2" value="" />
          <attvalue for="3" value="WILLIAM J. WALES; SASCHA KRAUS; MATTHIAS FILSER; CHRISTOPH STOCKMANN; JEFFREY G. COVIN" />
          <attvalue for="4" value="HTTPS://ORCID.ORG/0000-0001-6565-6439; HTTPS://ORCID.ORG/0000-0003-4886-7482; HTTPS://ORCID.ORG/0000-0002-1031-2820; HTTPS://ORCID.ORG/0000-0003-3054-4765; HTTPS://ORCID.ORG/0000-0003-1627-5300" />

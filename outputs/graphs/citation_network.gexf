      <node id="HILLS G, 2008" label="HILLS G, 2008">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="SOME THEORETICAL FOUNDATIONS OF ENTREPRENEURIAL MARKETING" />
          <attvalue for="2" value="HILLS G.E.; HULTMAN C.M." />
          <attvalue for="3" value="GERALD E. HILLS; CLAES M. HULTMAN" />
          <attvalue for="4" value="; " />
          <attvalue for="5" value="ENTREPRENEURIAL MARKETING IS A SCHOLARLY CONCEPT THAT IS BEGINNING TO BLOSSOM. THE QUANTITY AND QUALITY OF RELATED RESEARCH AND WRITING IS INCREASING AND THEORETICAL AS WELL AS EMPIRICAL WORKS ARE EX-PANDING THE FRONTIERS OF KNOWLEDGE. IT IS OUR HOPE THAT THIS PAPER WILL STIR CREATIVE THINKING AMONG THE READERS AS WE COMBINE SEVERAL IMPORTANT DOMAINS." />
          <attvalue for="6" value="2008.0" />
          <attvalue for="7" value="" />

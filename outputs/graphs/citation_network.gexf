        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="TOWARDS A MODEL OF ENTREPRENEURIAL MARKETING FOR RURAL WOMEN: A CASE STUDY APPROACH" />
          <attvalue for="2" value="MERRILEES B.; MANKALOW G." />

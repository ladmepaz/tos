      <node id="BENNETT R, 1984, BUS HORIZ" label="BENNETT R, 1984, BUS HORIZ">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="THE PRODUCT LIFE CYCLE TRAP" />
          <attvalue for="2" value="BENNETT R.; COOPER R.G." />

        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="VALUES AND COMPETITIVE ADVANTAGES BASED ON CUSTOMER VALUE PROPOSITIONS" />
          <attvalue for="2" value="FORREST J.Y.; YONG L." />

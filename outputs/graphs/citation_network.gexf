          <attvalue for="1" value="EXPLORATORY STUDY OF THE BPM TOOLS USED BY ROMANIAN INDUSTRIAL SERVICE COMPANIES TO INCREASE BUSINESS PERFORMANCE" />
          <attvalue for="2" value="" />
          <attvalue for="3" value="ANDREEA BARBU; PETRONELA CRISTINA SIMION; MIRONA ANA MARIA POPESCU; IUSTINA CRISTINA COSTEA MARCU; MIHAI VALERIU POPESCU" />

      <node id="ECKHARDT J, 2002, J MANAGE" label="ECKHARDT J, 2002, J MANAGE">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="OPPORTUNITIES AND ENTREPRENEURSHIP" />
          <attvalue for="2" value="ECKHARDT J." />
          <attvalue for="3" value="JON ECKHARDT" />
          <attvalue for="4" value="HTTPS://ORCID.ORG/0000-0001-6980-8903" />
          <attvalue for="5" value="THIS ARTICLE EXTENDS AND ELABORATES THE PERSPECTIVE ON ENTREPRENEURSHIP ARTICULATED BY SHANE AND VENKATARAMAN (2000) AND VENKATARAMAN (1997) BY EXPLAINING IN MORE DETAIL THE ROLE OF OPPORTUNITIES IN THE ENTREPRENEURIAL PROCESS. IN PARTICULAR, THE ARTICLE EXPLAINS THE IMPORTANCE OF EXAMINING ENTREPRENEURSHIP THROUGH A DISEQUILIBRIUM FRAMEWORK THAT FOCUSES ON THE CHARACTERISTICS AND EXISTENCE OF ENTREPRENEURIAL OPPORTUNITIES. IN ADDITION, THE ARTICLE DESCRIBES SEVERAL TYPOLOGIES OF OPPORTUNITIES AND THEIR IMPLICATIONS FOR UNDERSTANDING ENTREPRENEURSHIP." />
          <attvalue for="6" value="2002.0" />
          <attvalue for="7" value="JOURNAL OF MANAGEMENT" />
          <attvalue for="8" value="J MANAGE" />
          <attvalue for="9" value="" />
          <attvalue for="10" value="10.1016/S0149-2063(02)00225-8" />
          <attvalue for="11" value="10.1016/s0149-2063(02)00225-8" />
        </attvalues>
      </node>

      <node id="ASTUTI R, 2020, INT J ENTREP VENTURING" label="ASTUTI R, 2020, INT J ENTREP VENTURING">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="ENTREPRENEURIAL MARKETING ORIENTATION OF YOUNG SME OWNERS IN INDONESIA" />
          <attvalue for="2" value="ASTUTI R.D.; BALQIAH T.E." />

      </node>
      <node id="HILL J, 2001, INT J ENTREP BEHAV RES" label="HILL J, 2001, INT J ENTREP BEHAV RES">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="A MULTIDIMENSIONAL STUDY OF THE KEY DETERMINANTS OF EFFECTIVE SME MARKETING ACTIVITY: PART 2" />
          <attvalue for="2" value="HILL J." />
          <attvalue for="3" value="JIMMY HILL" />
          <attvalue for="4" value="" />
          <attvalue for="5" value="THIS PAPER FORMS PART 2 OF A MONOGRAPH DETAILING A STUDY THAT SOUGHT TO EXAMINE THE KEY DETERMINANTS OF SME MARKETING. IT REPORTS THE KEY FINDINGS WITH RESPECT TO MARKETING COMPETENCY IN SMES, EXPLORES THE STRONG SALES ORIENTATION OF SUCH FIRMS, EXAMINES THE NATURE AND USE OF SME PERSONAL CONTACT NETWORKS AND CONSIDERS TO WHAT EXTENT FORMAL MARKETING PLANNING IS PRACTICED IN SUCH ENTERPRISES. NEW INSIGHTS TO THESE IMPORTANT AREAS OF SMALL FIRM RESEARCH ARE PRESENTED. A NEW MODEL OF SME MARKETING COMPETENCY IS DEVELOPED, DEPICTING COMPETENCIES AT THREE LEVELS, FOUNDATION, TRANSITIONAL AND MARKETING IN PRACTICE. THE MONOGRAPH CONCLUDES WITH A HOLISTIC INTERPRETATION OF THE DATA THAT ENABLES THE DEVELOPMENT OF A NEW MODEL OF SME MARKETING." />
          <attvalue for="6" value="2001.0" />
          <attvalue for="7" value="INTERNATIONAL JOURNAL OF ENTREPRENEURIAL BEHAVIOUR &amp; RESEARCH" />
          <attvalue for="8" value="INT J ENTREP BEHAV RES" />
          <attvalue for="9" value="" />
          <attvalue for="10" value="10.1108/EUM0000000006538" />
          <attvalue for="11" value="10.1108/eum0000000006538" />
        </attvalues>
      </node>
      <node id="KERRIGAN F, 2011, J MARK MANAGE" label="KERRIGAN F, 2011, J MARK MANAGE">

      <node id="MIN S, 2006, J MARKETING" label="MIN S, 2006, J MARKETING">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="MARKET PIONEER AND EARLY FOLLOWER SURVIVAL RISKS: A CONTINGENCY ANALYSIS OF REALLY NEW VERSUS INCREMENTALLY NEW PRODUCT-MARKETS" />
          <attvalue for="2" value="MIN S.; KALWANI M.U.; ROBINSON W.T." />
          <attvalue for="3" value="SUNGWOOK MIN; MANOHAR U. KALWANI; WILLIAM T. ROBINSON" />
          <attvalue for="4" value="; ; " />
          <attvalue for="5" value="DOES THE FIRST ENTRANT IN A NEW MARKET HAVE A DIFFICULT TIME SURVIVING OR DO FIRST-MOVER ADVANTAGES PROVIDE PROTECTION FROM OUTRIGHT FAILURE? THIS EMPIRICAL STUDY OF 264 NEW INDUSTRIAL PRODUCT-MARKETS YIELDS INSIGHTS INTO THIS CONTROVERSIAL RESEARCH TOPIC. THE KEY DATA ANALYSIS INSIGHTS ARISE THROUGH A COMPARISON OF SURVIVAL RISKS IN MARKETS THAT WERE STARTED WITH A REALLY NEW PRODUCT AND IN THOSE THAT WERE STARTED WITH AN INCREMENTAL INNOVATION. WHEN A PIONEER STARTS A NEW MARKET WITH A REALLY NEW PRODUCT, IT CAN BE A MAJOR CHALLENGE JUST TO SURVIVE. IN CONTRAST, IN MARKETS STARTED BY AN INCREMENTAL INNOVATION, MARKET PIONEER SURVIVAL RISKS ARE MUCH LOWER. NOTABLY, EARLY FOLLOWERS HAVE THE SAME SURVIVAL RISK ACROSS BOTH TYPES OF MARKETS. OVERALL, THESE RESULTS INDICATE THAT IN MARKETS STARTED BY A REALLY NEW PRODUCT, THE FIRST TO MARKET IS OFTEN THE FIRST TO FAIL. IN CONTRAST, IN MARKETS STARTED BY AN INCREMENTAL INNOVATION, IT APPEARS THAT FIRST-MOVER ADVANTAGES PROTECT THE PIONEER FROM OUTRIGHT FAILURE." />
          <attvalue for="6" value="2006.0" />
          <attvalue for="7" value="JOURNAL OF MARKETING" />
          <attvalue for="8" value="J MARKETING" />
          <attvalue for="9" value="" />
          <attvalue for="10" value="10.1509/JMKG.70.1.015.QXD" />
          <attvalue for="11" value="10.1509/jmkg.70.1.015.qxd" />
        </attvalues>
      </node>
      <node id="MORRISH S, 2009, J RES MARK ENTREP" label="MORRISH S, 2009, J RES MARK ENTREP">
        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="PORTFOLIO ENTREPRENEURS: AN EFFECTUATION APPROACH TO MULTIPLE VENTURE DEVELOPMENT" />
          <attvalue for="2" value="" />
          <attvalue for="3" value="SUSSIE MORRISH" />
          <attvalue for="4" value="HTTPS://ORCID.ORG/0000-0003-2900-3232" />

        <attvalues>
          <attvalue for="0" value="true" />
          <attvalue for="1" value="REVISITING THE ‘CONCENTRATION VS SPREADING DEBATE’: PERCEIVED RISK AND STRATEGIC FLEXIBILITY IN DECISION-MAKING FOLLOWING AN UNANTICIPATED ENVIRONMENTAL MARKET DISRUPTION" />
